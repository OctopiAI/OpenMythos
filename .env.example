# Copy to .env for local dev, or paste these into Coolify's Environment Variables UI.

# Bearer token clients must send in Authorization header.
# Leave empty to disable auth entirely (not recommended for public domain).
API_KEY=change-me-to-a-long-random-string

# HuggingFace token — used at image build time to download the tokenizer,
# and at runtime if any other HF downloads are triggered.
# Needs only "read" scope. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# "cuda" if you have a GPU, "cpu" otherwise
DEVICE=cuda

# Path inside the container to a .pt checkpoint file.
# Leave empty to run with random weights (architecture testing only).
# Example: /app/checkpoints/mythos_1b.pt
CHECKPOINT_PATH=

# Model architecture env vars (only change if you trained a custom config)
VOCAB_SIZE=200000
DIM=256
N_HEADS=8
MAX_SEQ_LEN=512
MAX_LOOP_ITERS=4
ATTN_TYPE=mla
